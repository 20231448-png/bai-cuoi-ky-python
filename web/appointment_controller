from flask import Blueprint, render_template, request, redirect, url_for, flash
from flask_login import login_required, current_user
from app.extensions import db
from app.models import Appointment, Patient, Service
from datetime import datetime

appointment_bp = Blueprint("appointment", __name__)

@appointment_bp.route("/")
@login_required
def index():
    if current_user.role not in ["admin", "staff", "doctor"]:
        flash("Bạn không có quyền xem danh sách lịch hẹn.", "danger")
        return redirect(url_for("dashboard.home"))

    appointments = Appointment.query.order_by(Appointment.appointment_id.desc()).all()
    return render_template("appointments/index.html", appointments=appointments)

@appointment_bp.route("/create", methods=["GET", "POST"])
def create():
    services = Service.query.filter_by(status=True).all()

    if request.method == "POST":
        full_name = request.form.get("full_name")
        gender = request.form.get("gender")
        date_of_birth = request.form.get("date_of_birth")
        phone = request.form.get("phone")
        email = request.form.get("email")
        address = request.form.get("address")
        service_id = request.form.get("service_id")
        appointment_date = request.form.get("appointment_date")
        note = request.form.get("note")

        patient = Patient.query.filter_by(phone=phone).first()

        if not patient:
            patient = Patient(
                full_name=full_name,
                gender=gender if gender else None,
                date_of_birth=date_of_birth if date_of_birth else None,
                phone=phone,
                email=email,
                address=address
            )
            db.session.add(patient)
            db.session.flush()

        appointment = Appointment(
            patient_id=patient.patient_id,
            service_id=int(service_id),
            appointment_date=datetime.strptime(appointment_date, "%Y-%m-%dT%H:%M"),
            status="pending",
            note=note
        )

        db.session.add(appointment)
        db.session.commit()

        flash("Đăng ký khám thành công.", "success")
        return redirect(url_for("dashboard.home"))

    return render_template("appointments/create.html", services=services)
